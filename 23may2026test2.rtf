\f1\b \cf2 \cb1 \kerning1\expnd0\expndtw0 2.
\f2\b0 Retrieve the Project Name, Client Name, and the Total Hours Worked on that project, but only for projects managed by the 'Consulting' department.\
SELECT  p.project_name,p.client_name,\
    SUM(a.hours_worked)      AS total_hours\
FROM Projects p\
JOIN Assignments a ON p.project_id = a.project_id\
JOIN Departments d ON p.dept_id = d.dept_id\
WHERE d.dept_name = 'Consulting'\
GROUP BY p.project_name, p.client_name;\
\
\

\f1\b 4.
\f2\b0 List all Departments that have no Employees currently assigned to them.\
SELECT  d.dept_name,d.location_id\
FROM Departments d\
LEFT JOIN Employees e ON d.dept_id = e.dept_id\
WHERE e.employee_id IS NULL;\

\f1\b 5.
\f2\b0 Show the Manager Name, the Department Name they manage, and the total number of direct reports they have.\
SELECT \
    m.employee_name      AS manager_name,\
    d.dept_name,\
    COUNT(e.employee_id) AS total_reports\
FROM Employees e\
JOIN Employees m ON e.manager_id = m.employee_id\
JOIN Departments d ON m.dept_id = d.dept_id\
GROUP BY m.employee_name, d.dept_name\
ORDER BY total_reports DESC;\
\

\f1\b 6.
\f2\b0 Calculate the Average Hours Worked per Employee across all projects. List the Employee Name and the average hours.\
SELECT \
    e.employee_name,\
    AVG(a.hours_worked)      AS avg_hours\
FROM Employees e\
JOIN Assignments a ON e.employee_id = a.employee_id\
GROUP BY e.employee_name\
ORDER BY avg_hours DESC;\
\

\f1\b 7.
\f2\b0 Find the Department Name(s) that have an average salary above the company-wide average salary.\
SELECT \
    d.dept_name,\
    AVG(e.salary)        AS avg_salary\
FROM Employees e\
JOIN Departments d ON e.dept_id = d.dept_id\
GROUP BY d.dept_name\
HAVING AVG(e.salary) > (\
    SELECT AVG(salary)\
    FROM Employees\
);\

\f1\b 8.
\f2\b0 Identify the Client Name(s) whose projects have a total combined hours worked exceeding 500 hours.\
SELECT \
    p.client_name,\
    SUM(a.hours_worked)      AS total_hours\
FROM Projects p\
JOIN Assignments a ON p.project_id = a.project_id\
GROUP BY p.client_name\
HAVING SUM(a.hours_worked) > 500;\

\f1\b 9.
\f2\b0 For each Location, find the Department Name with the highest count of employees.\
SELECT \
    d.location_id,\
    d.dept_name,\
    COUNT(e.employee_id)     AS employee_count\
FROM Departments d\
JOIN Employees e ON d.dept_id = e.dept_id\
GROUP BY d.location_id, d.dept_name\
HAVING COUNT(e.employee_id) = (\
    SELECT MAX(emp_count)\
    FROM (\
        SELECT \
            d2.location_id,\
            COUNT(e2.employee_id)    AS emp_count\
        FROM Departments d2\
        JOIN Employees e2 ON d2.dept_id = e2.dept_id\
        GROUP BY d2.location_id, d2.dept_name\
    ) sub\
    WHERE sub.location_id = d.location_id\
);\
\pard\pardeftab720\sl278\slmult1\sa160\partightenfactor0

\f1\b \cf2 10.
\f2\b0 Calculate the total number of employees assigned to each Project, but only include projects that have more than 5 employees assigned\
SELECT \
    p.project_name,\
    COUNT(a.employee_id)     AS total_employees\
FROM Projects p\
JOIN Assignments a ON p.project_id = a.project_id\
GROUP BY p.project_name\
HAVING COUNT(a.employee_id) > 5;\
\
\pard\pardeftab720\sl278\slmult1\sa160\partightenfactor0

\f1\b \cf2 11.
\f2\b0 Find the Employee Name(s) who work on ALL projects managed by the 'R&D' department.\
SELECT \
    e.employee_name\
FROM Employees e\
JOIN Assignments a ON e.employee_id = a.employee_id\
JOIN Projects p ON a.project_id = p.project_id\
JOIN Departments d ON p.dept_id = d.dept_id\
WHERE d.dept_name = 'R&D'\
GROUP BY e.employee_name\
HAVING COUNT(DISTINCT p.project_id) = (\
    SELECT COUNT(project_id)\
    FROM Projects p2\
    JOIN Departments d2 ON p2.dept_id = d2.dept_id\
    WHERE d2.dept_name = 'R&D'\
);\

\f1\b 12.
\f2\b0 Retrieve the Department Name(s) that have employees assigned to more than one project.\
SELECT DISTINCT\
    d.dept_name\
FROM Departments d\
JOIN Employees e ON d.dept_id = e.dept_id\
JOIN Assignments a ON e.employee_id = a.employee_id\
GROUP BY d.dept_name, e.employee_id\
HAVING COUNT(DISTINCT a.project_id) > 1;\
\
\pard\pardeftab720\sl278\slmult1\sa160\partightenfactor0

\f1\b \cf2 13.\

\f2\b0 Write a query to list the Employee Name and Project Name for any employee who has worked less than 10 hours on a project\
SELECT \
    e.employee_name,\
    p.project_name,\
    a.hours_worked\
FROM Employees e\
JOIN Assignments a ON e.employee_id = a.employee_id\
JOIN Projects p ON a.project_id = p.project_id\
WHERE a.hours_worked < 10;\
\

\f1\b 14.\

\f2\b0 Find the Project Name(s) that have no assigned employees.\
SELECT \
    p.project_name,\
    p.client_name\
FROM Projects p\
LEFT JOIN Assignments a ON p.project_id = a.project_id\
WHERE a.employee_id IS NULL;\
\

\f1\b 15.\

\f2\b0 Select the Employee Name(s) whose salary is greater than the maximum salary in their own department.\
SELECT \
    e.employee_name,\
    e.salary\
FROM Employees e\
WHERE e.salary > (\
    SELECT MAX(e2.salary)\
    FROM Employees e2\
    WHERE e2.dept_id = e.dept_id\
    AND e2.employee_id != e.employee_id\
);\

\f1\b 16.\

\f2\b0 Assuming the Assignments table has a start_date column, find the Employee Name and their oldest project start date.\
SELECT \
    e.employee_name,\
    MIN(a.start_date)        AS oldest_start_date\
FROM Employees e\
JOIN Assignments a ON e.employee_id = a.employee_id\
GROUP BY e.employee_name\
ORDER BY oldest_start_date ASC;\
\

\f1\b 17.\

\f2\b0 Write a MySQL query using the DATE_FORMAT function to list all projects that were active in the year 2023.\
SELECT \
    p.project_name,\
    p.client_name,\
    DATE_FORMAT(p.start_date, '%Y')      AS start_year\
FROM Projects p\
WHERE DATE_FORMAT(p.start_date, '%Y') = '2023';\
}