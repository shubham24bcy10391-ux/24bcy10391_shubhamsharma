\cf2 \cb3 \strokec2 10. Write an SQL query to show all departments along with the total number of people in there.\cb1 \
\
SELECT DEPARTMENT, COUNT(*) AS WORKER_COUNT \
FROM Worker \
GROUP BY DEPARTMENT;\
